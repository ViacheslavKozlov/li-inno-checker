{
  "name": "li-inno-checker",
  "version": "1.3.0",
  "description": "Telegram bot that checks LinkedIn profile statuses and stores screenshot proof in MongoDB.",
  "license": "MIT",
  "main": "dist/index.js",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsx src/scripts/run-check.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "husky || true"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "cronstrue": "^3.20.0",
    "dotenv": "^17.4.2",
    "form-data": "^4.0.6",
    "mongoose": "^9.7.1",
    "node-cron": "^4.4.1",
    "pino": "^10.3.1",
    "playwright": "^1.61.0",
    "sharp": "^0.35.2",
    "telegraf": "^4.16.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "mongodb-memory-server": "^11.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
