# --- MongoDB Atlas ---
MONGODB_USERNAME=your_user
MONGODB_PASSWORD=your_password
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Optional: legacy single-chat id (unused in multi-user mode, kept for reference)
TELEGRAM_CHAT_ID=

# --- Checker / scheduler (all optional; defaults shown) ---
# Weekly on Monday at 09:00 (cron expression, server local time)
CRON_SCHEDULE=0 9 * * 1
# Run chromium headless
BROWSER_HEADLESS=true
# Add Chromium --no-sandbox/--disable-dev-shm-usage. Required when running as
# root in a container (Docker/Railway); leave false for local runs. The Docker
# image sets this to true for you.
BROWSER_NO_SANDBOX=false
# Per-page navigation timeout (ms)
CHECK_TIMEOUT_MS=30000
# How many profiles to check in parallel
CHECK_CONCURRENCY=2
# Delay between checks to reduce rate-limiting (ms)
CHECK_DELAY_MS=3000
# Process-wide cap on simultaneous on-demand /check runs (each opens a browser)
MANUAL_CHECK_CONCURRENCY=2
# Delete stored checks + screenshots older than N days (0 = keep forever)
CHECK_RETENTION_DAYS=90
# JPEG quality (1-100) for stored screenshots; lower = smaller files / cheaper storage
SCREENSHOT_QUALITY=60
# pino log level: trace | debug | info | warn | error
LOG_LEVEL=info
# Optional comma-separated Telegram user ids allowed to use the bot (empty = open to all)
ALLOWED_TELEGRAM_IDS=
